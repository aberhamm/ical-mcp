# Required: CalDAV server URL
# iCloud:    https://caldav.icloud.com
# Fastmail:  https://caldav.fastmail.com/dav/calendars
# Nextcloud: https://your-server.com/remote.php/dav
ICAL_MCP_URL=https://caldav.icloud.com

# Required: CalDAV credentials
# For iCloud: use your Apple ID email and an app-specific password
# Generate at: https://account.apple.com → Sign-In and Security → App-Specific Passwords
ICAL_MCP_USERNAME=your@icloud.com
ICAL_MCP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: default timezone for display (default: UTC)
ICAL_MCP_TIMEZONE=UTC

# Optional: calendars that allow write operations (create/update/delete)
# All calendars are READ-ONLY by default. You must explicitly opt in.
#   Single calendar:   ICAL_MCP_WRITABLE_CALENDARS=home
#   Multiple:          ICAL_MCP_WRITABLE_CALENDARS=home,Work
#   All calendars:     ICAL_MCP_WRITABLE_CALENDARS=*
#   Not set or empty:  all calendars are read-only
ICAL_MCP_WRITABLE_CALENDARS=
